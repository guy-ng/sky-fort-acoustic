## 4. Python implementation with pyroomacoustics and Acoular

Two viable paths exist for the beamforming engine. **Pyroomacoustics** provides the most natural DOA interface with native azimuth/colatitude output and built-in SRP-PHAT/MUSIC algorithms. **Acoular** provides a richer acoustic imaging framework with the UMA-16V2 geometry built in, but requires more manual work to produce az/el output.

### Recommended path: pyroomacoustics for DOA

```bash
pip install pyroomacoustics sounddevice numpy scipy pyqtgraph pyzmq acoular
```

```python
import numpy as np
import pyroomacoustics as pra

# --- Define UMA-16V2 geometry (4x4 rectangular, 42mm spacing) ---
spacing = 0.042
mic_locs = []
for row in range(4):
    for col in range(4):
        x = (col - 1.5) * spacing
        y = (row - 1.5) * spacing
        mic_locs.append([x, y, 0.0])
L = np.array(mic_locs).T  # shape (3, 16)

# --- For VERTICAL mounting: rotate array ---
# Original: array in x-y plane, boresight along +z
# Vertical mount: array in x-z plane, boresight along +y
# Rotation: swap y and z coordinates
L_vertical = L.copy()
L_vertical[1, :], L_vertical[2, :] = L[2, :].copy(), L[1, :].copy()

# --- Configure SRP-PHAT DOA ---
fs = 48000
nfft = 2048

# Define scanning grid
az_grid = np.linspace(-np.pi, np.pi, 73)         # 5° steps, 73 points
colat_grid = np.linspace(0.1, np.pi - 0.1, 37)   # ~5° steps, avoid poles

doa = pra.doa.SRP(
    L_vertical, fs, nfft,
    c=343.0,
    num_src=1,
    dim=3,
    azimuth=az_grid,
    colatitude=colat_grid
)

# --- Process one frame ---
def process_frame(audio_chunk):
    """
    audio_chunk: np.ndarray, shape (n_samples, 16), float32
    Returns: az_deg, el_deg, power_map (n_el × n_az)
    """
    # STFT
    X = pra.transform.stft.analysis(audio_chunk.T, nfft, nfft // 2)
    X = X.transpose([2, 1, 0])  # (n_mics, n_freq, n_frames)
    
    # Locate sources in 500–4000 Hz band
    doa.locate_sources(X, freq_range=[500, 4000])
    
    # Extract results
    az_rad = doa.azimuth_recon[0]
    colat_rad = doa.colatitude_recon[0]
    el_rad = np.pi / 2 - colat_rad  # convert colatitude to elevation
    
    az_deg = np.degrees(az_rad)
    el_deg = np.degrees(el_rad)
    
    # Get spatial spectrum for heatmap
    # doa.grid.values contains the SRP power at each grid point
    power_map = doa.grid.values.reshape(len(colat_grid), len(az_grid))
    
    return az_deg, el_deg, power_map
```

### Coordinate system for vertical mounting

When the UMA-16V2 is mounted **vertically on a PTZ head** (array face pointing forward), the coordinate mapping is:

```
Physical world          →  Array coordinates (standard: array in x-y plane)
Horizontal (left/right) →  x-axis  →  Azimuth
Vertical (up/down)      →  y-axis  →  Elevation  
Forward (toward target) →  z-axis  →  Boresight (depth)

For vertical mount, rotate the mic geometry so the array lies in the x-z plane:
  - x stays (horizontal / azimuth)
  - z becomes vertical (was y) → elevation
  - y becomes depth/boresight (was z)

Azimuth:   angle in horizontal plane from boresight, atan2(x, y_depth)
Elevation: angle in vertical plane from boresight, atan2(z_vertical, y_depth)
```

### Acoular-based approach with custom spherical grid

```python
import acoular as ac
import numpy as np
from pathlib import Path

# Load UMA-16 geometry
micgeofile = Path(ac.__file__).parent / 'xml' / 'minidsp_uma16.xml'
mg = ac.MicGeom(file=str(micgeofile))

# Create spherical steering grid (no built-in SphericalGrid in Acoular)
R = 5.0  # focus distance in meters (far-field approximation)
az_vals = np.linspace(-60, 60, 49) * np.pi / 180   # azimuth
el_vals = np.linspace(-60, 60, 49) * np.pi / 180   # elevation
az_mesh, el_mesh = np.meshgrid(az_vals, el_vals)
az_flat, el_flat = az_mesh.ravel(), el_mesh.ravel()

# Spherical to Cartesian (boresight = +z for standard Acoular)
x = R * np.sin(az_flat) * np.cos(el_flat)
y = R * np.sin(el_flat)
z = R * np.cos(az_flat) * np.cos(el_flat)
grid_pos = np.vstack([x, y, z])

steering_grid = ac.ImportGrid(pos=grid_pos)
st = ac.SteeringVector(grid=steering_grid, mics=mg)

# Real-time time-domain beamforming chain
sd_gen = ac.SoundDeviceSamplesGenerator(device=0, num_channels=16)
bt = ac.BeamformerTime(source=sd_gen, steer=st)
ft = ac.FiltOctave(source=bt, band=2000, fraction='Third octave')
pt = ac.TimePower(source=ft)
avg = ac.TimeAverage(source=pt, naverage=2048)

# Processing loop
for block in avg.result(num=1):
    power = block[0]  # 1D array, length = n_grid_points
    power_map = power.reshape(len(el_vals), len(az_vals))
    Lm = ac.L_p(power_map)
    
    # Peak detection
    peak_idx = np.unravel_index(np.argmax(Lm), Lm.shape)
    el_deg = np.degrees(el_vals[peak_idx[0]])
    az_deg = np.degrees(az_vals[peak_idx[1]])
```

### Custom SRP-PHAT (vectorized NumPy, no library dependency)

```python
import numpy as np
from scipy.fft import rfft, rfftfreq

class SRPPHATBeamformer:
    """Vectorized SRP-PHAT for real-time DOA estimation."""
    
    def __init__(self, mic_pos, fs=48000, nfft=2048, c=343.0,
                 az_range=(-60, 60), el_range=(-60, 60), resolution=5.0,
                 freq_range=(500, 4000)):
        self.mic_pos = mic_pos   # (3, n_mics)
        self.fs = fs
        self.nfft = nfft
        self.c = c
        self.freq_range = freq_range
        
        # Build scanning grid (unit direction vectors)
        az = np.arange(az_range[0], az_range[1] + 0.1, resolution)
        el = np.arange(el_range[0], el_range[1] + 0.1, resolution)
        self.az_deg = az
        self.el_deg = el
        az_rad = np.radians(az)
        el_rad = np.radians(el)
        az_mesh, el_mesh = np.meshgrid(az_rad, el_rad)
        
        # Unit vectors for each grid direction (boresight = +z)
        dirs = np.vstack([
            np.sin(az_mesh.ravel()) * np.cos(el_mesh.ravel()),
            np.sin(el_mesh.ravel()),
            np.cos(az_mesh.ravel()) * np.cos(el_mesh.ravel())
        ])  # (3, n_grid)
        
        # Precompute TDOA for all mic pairs and grid points
        n_mics = mic_pos.shape[1]
        self.pair_delays = []  # list of (n_grid,) arrays
        self.pairs = []
        for i in range(n_mics):
            for j in range(i + 1, n_mics):
                d = mic_pos[:, i] - mic_pos[:, j]
                tau = dirs.T @ d / c   # (n_grid,) in seconds
                self.pair_delays.append(tau)
                self.pairs.append((i, j))
        
        # Frequency bin indices for the target range
        freqs = rfftfreq(nfft, 1 / fs)
        self.freq_mask = (freqs >= freq_range[0]) & (freqs <= freq_range[1])
        self.freqs_sel = freqs[self.freq_mask]
        
        # Precompute phase matrix: (n_pairs, n_freq, n_grid)
        self.n_grid = dirs.shape[1]
        self.grid_shape = (len(el), len(az))
        
        # Store as stacked array for vectorized computation
        tau_all = np.array(self.pair_delays)  # (n_pairs, n_grid)
        # Phase: exp(2πj·f·τ) for each pair, freq, grid point
        # Shape: (n_pairs, n_freq_sel, n_grid)
        self.phase_matrix = np.exp(
            2j * np.pi * self.freqs_sel[None, :, None] * tau_all[:, None, :]
        )
    
    def process(self, audio_chunk):
        """
        audio_chunk: (n_samples, n_mics), float32
        Returns: az_deg, el_deg, power_map_db (n_el, n_az)
        """
        # FFT
        X = rfft(audio_chunk, n=self.nfft, axis=0)  # (nfft//2+1, n_mics)
        X_sel = X[self.freq_mask, :]  # (n_freq_sel, n_mics)
        
        # Compute SRP-PHAT
        power_map = np.zeros(self.n_grid)
        
        for idx, (i, j) in enumerate(self.pairs):
            cross = X_sel[:, i] * np.conj(X_sel[:, j])
            cross_phat = cross / (np.abs(cross) + 1e-12)
            
            # (n_freq, n_grid) → sum over freq
            contribution = np.real(
                (cross_phat[:, None] * self.phase_matrix[idx]).sum(axis=0)
            )
            power_map += contribution
        
        # Reshape and find peak
        power_map_2d = power_map.reshape(self.grid_shape)
        power_map_db = 10 * np.log10(
            np.maximum(power_map_2d, 1e-30) / np.maximum(power_map_2d.max(), 1e-30)
        )
        
        peak_idx = np.unravel_index(np.argmax(power_map_2d), self.grid_shape)
        az = self.az_deg[peak_idx[1]]
        el = self.el_deg[peak_idx[0]]
        
        return az, el, power_map_db
```

### Peak detection with sub-grid interpolation

```python
def parabolic_interpolation_2d(power_map, peak_idx, az_values, el_values):
    """Refine peak location with parabolic (quadratic) interpolation."""
    i, j = peak_idx
    if 0 < i < power_map.shape[0] - 1 and 0 < j < power_map.shape[1] - 1:
        # Azimuth refinement
        a, b, c = power_map[i, j-1], power_map[i, j], power_map[i, j+1]
        dj = 0.5 * (a - c) / (a - 2*b + c + 1e-30)
        az_interp = az_values[j] + dj * (az_values[1] - az_values[0])
        
        # Elevation refinement
        a, b, c = power_map[i-1, j], power_map[i, j], power_map[i+1, j]
        di = 0.5 * (a - c) / (a - 2*b + c + 1e-30)
        el_interp = el_values[i] + di * (el_values[1] - el_values[0])
        return az_interp, el_interp
    return az_values[j], el_values[i]

def find_multiple_peaks(power_map_db, az_values, el_values, 
                         threshold_db=6, min_distance=3):
    """Find multiple sources in the beamforming map."""
    from scipy.ndimage import maximum_filter, label
    local_max = maximum_filter(power_map_db, size=min_distance)
    peaks = (power_map_db == local_max) & (power_map_db > power_map_db.max() - threshold_db)
    labeled, n_features = label(peaks)
    results = []
    for n in range(1, n_features + 1):
        region = np.where(labeled == n)
        idx = np.argmax(power_map_db[region])
        ri, ci = region[0][idx], region[1][idx]
        az, el = parabolic_interpolation_2d(
            power_map_db, (ri, ci), az_values, el_values)
        results.append({'az_deg': az, 'el_deg': el, 
                        'power_db': power_map_db[ri, ci]})
    return results
```

