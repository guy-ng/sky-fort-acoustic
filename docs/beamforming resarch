## 5. Real-time visualization with PyQtGraph at 15 fps

PyQtGraph renders 2D image updates **75–150× faster** than Matplotlib, achieving >1000 fps for plot updates versus Matplotlib's ~40 fps in benchmarks. For a beamforming heatmap of ~49×25 pixels (5° resolution), **15 fps is trivially achievable**.

```python
import pyqtgraph as pg
from pyqtgraph.Qt import QtCore, QtWidgets
import numpy as np

pg.setConfigOption('imageAxisOrder', 'row-major')  # Critical for performance

class BeamformingHeatmap:
    """Real-time azimuth/elevation heatmap display."""
    
    def __init__(self, az_range=(-60, 60), el_range=(-60, 60), fps=15):
        self.app = QtWidgets.QApplication.instance() or QtWidgets.QApplication([])
        self.win = pg.GraphicsLayoutWidget(title="Drone Detector — Acoustic Heatmap")
        self.win.resize(900, 500)
        
        self.plot = self.win.addPlot(title="SRP-PHAT Acoustic Power Map")
        self.plot.setLabel('bottom', 'Azimuth (°)')
        self.plot.setLabel('left', 'Elevation (°)')
        
        # ImageItem for heatmap
        self.img = pg.ImageItem()
        self.plot.addItem(self.img)
        self.img.setRect(az_range[0], el_range[0],
                         az_range[1] - az_range[0], el_range[1] - el_range[0])
        
        # Colorbar (viridis, dB scale)
        cm = pg.colormap.get('inferno')
        self.bar = pg.ColorBarItem(values=(-30, 0), cmap=cm)
        self.bar.setImageItem(self.img, insert_in=self.plot)
        
        # Crosshair lines
        self.v_line = pg.InfiniteLine(angle=90, movable=False, 
                                       pen=pg.mkPen('lime', width=1, style=QtCore.Qt.DashLine))
        self.h_line = pg.InfiniteLine(angle=0, movable=False, 
                                       pen=pg.mkPen('lime', width=1, style=QtCore.Qt.DashLine))
        self.plot.addItem(self.v_line)
        self.plot.addItem(self.h_line)
        
        # Peak marker
        self.peak_marker = pg.ScatterPlotItem(
            size=18, pen=pg.mkPen('lime', width=2),
            brush=pg.mkBrush(0, 255, 0, 80), symbol='crosshair')
        self.plot.addItem(self.peak_marker)
        
        # Timer for updates
        self.timer = QtCore.QTimer()
        self.timer.timeout.connect(self._update)
        self.timer.start(int(1000 / fps))
        
        self._latest_data = None
        self.win.show()
    
    def set_data(self, power_map_db, peak_az, peak_el):
        """Thread-safe data setter (called from beamforming process via queue)."""
        self._latest_data = (power_map_db.astype(np.float32), peak_az, peak_el)
    
    def _update(self):
        if self._latest_data is None:
            return
        power_db, az, el = self._latest_data
        self.img.setImage(power_db, autoLevels=False, levels=(-30, 0))
        self.v_line.setPos(az)
        self.h_line.setPos(el)
        self.peak_marker.setData([az], [el])
    
    def run(self):
        self.app.exec()
```

Key performance optimizations: use **row-major C-contiguous float32** arrays, disable `autoLevels`, set explicit `levels`, and keep the colormap LUT under 256 entries.

