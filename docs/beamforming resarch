mg = ac.MicGeom(file=str(micgeofile))
# mg.mpos_tot → shape (3, 16), rows are [x, y, z]

# Manual definition (approximate, relative to center, in meters):
# Row/Col:   Col0=-0.063  Col1=-0.021  Col2=+0.021  Col3=+0.063
# Row0 y=-0.063,  Row1 y=-0.021,  Row2 y=+0.021,  Row3 y=+0.063
spacing = 0.042
pos = []
for row in range(4):
    for col in range(4):
        x = (col - 1.5) * spacing  # -0.063, -0.021, +0.021, +0.063
