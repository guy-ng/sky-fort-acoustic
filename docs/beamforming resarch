## 7. Configuration and complete class design

```python
from dataclasses import dataclass, field
from typing import Tuple, Optional
import numpy as np

@dataclass
class DroneDetectorConfig:
    # Audio hardware
    sample_rate: int = 48000
    channels: int = 16
    device_name: str = 'UMA-16'
    blocksize: int = 2048
    
    # UMA-16V2 mic positions (4×4 rectangular, 42mm spacing)
    mic_spacing: float = 0.042
    
    # STFT parameters
    fft_size: int = 4096
    window: str = 'hann'
    hop_size: int = 512
    
    # Beamforming grid
    az_range: Tuple[float, float] = (-60.0, 60.0)
    el_range: Tuple[float, float] = (-60.0, 60.0)
    az_resolution: float = 5.0
    el_resolution: float = 5.0
    freq_range: Tuple[float, float] = (500.0, 4000.0)
    speed_of_sound: float = 343.0
    
    # Detection
    detection_threshold_db: float = -15.0
    min_peak_separation_deg: float = 15.0
    
    # Visualization
    colormap: str = 'inferno'
    vmin_db: float = -30.0
    vmax_db: float = 0.0
    target_fps: int = 15
    
    # ZeroMQ
    zmq_pub_addr: str = 'tcp://*:5556'
    zmq_topic: str = 'detection'
    
    # Ring buffer
    ring_buffer_seconds: float = 5.0
    
    def get_mic_positions(self) -> np.ndarray:
        """Return (3, 16) mic position array for UMA-16V2."""
        pos = []
        for row in range(4):
            for col in range(4):
                x = (col - 1.5) * self.mic_spacing
                y = (row - 1.5) * self.mic_spacing
                pos.append([x, y, 0.0])
        return np.array(pos).T
    
    def get_mic_positions_vertical(self) -> np.ndarray:
        """Return positions for vertically-mounted array (boresight = +y)."""
        p = self.get_mic_positions()
        # Swap y and z for vertical mount
        return np.array([p[0], p[2], p[1]])
